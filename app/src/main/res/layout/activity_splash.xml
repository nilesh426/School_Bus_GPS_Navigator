<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="#F6F4FA"
    android:padding="24dp">

    <ImageView
        android:id="@+id/ivSplashLogo"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:alpha="0"
        android:scaleX="0.85"
        android:scaleY="0.85"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="App Logo" />

    <TextView
        android:id="@+id/tvSplashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:alpha="0"
        android:text="School Bus App"
        android:textColor="#2E2A35"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSplashSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:alpha="0"
        android:text="Safe and smart school bus tracking"
        android:textColor="#7A7485"
        android:textSize="18sp" />

</LinearLayout>